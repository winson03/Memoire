<%- include('partials/head', { title: 'New user' }) %>
<div class="shell">
  <%- include('partials/sidebar') %>
  <main class="main">
    <%- include('partials/topbar', { pageTitle: 'New user', searchAction: '/admin/users' }) %>
    <div class="content">
      <div class="page">

        <a href="/admin/users" class="btn-ghost" style="display:inline-block;margin-bottom:20px;">← Back to users</a>

        <form method="post" action="/admin/users">
          <section class="settings-section">
            <h3>Account details</h3>
            <div class="settings-fields">
              <div class="settings-field">
                <label class="field-label" style="font-size:12px;">Name</label>
                <input class="input" name="name" value="<%= form.name || '' %>" required>
              </div>
              <div class="settings-field">
                <label class="field-label" style="font-size:12px;">Username <span style="color:rgba(58,50,42,0.45);">(optional)</span></label>
                <input class="input" name="username" value="<%= form.username || '' %>" placeholder="username">
              </div>
            </div>
            <div class="settings-fields" style="margin-top:16px;">
              <div class="settings-field">
                <label class="field-label" style="font-size:12px;">Email</label>
                <input class="input" type="email" name="email" value="<%= form.email || '' %>" placeholder="you@example.com" required>
              </div>
              <div class="settings-field">
                <label class="field-label" style="font-size:12px;">Phone <span style="color:rgba(58,50,42,0.45);">(optional)</span></label>
                <input class="input" type="tel" name="phone" value="<%= form.phone || '' %>" placeholder="Phone number">
              </div>
            </div>
            <div class="settings-fields" style="margin-top:16px;">
              <div class="settings-field">
                <label class="field-label" style="font-size:12px;">Date of birth <span style="color:rgba(58,50,42,0.45);">(optional)</span></label>
                <input class="input" type="date" name="dob" value="<%= form.dob || '' %>">
              </div>
              <div class="settings-field">
                <label class="field-label" style="font-size:12px;">Role</label>
                <select class="input" name="role">
                  <option value="storyteller" <%= form.role === 'admin' ? '' : 'selected' %>>Storyteller</option>
                  <option value="admin" <%= form.role === 'admin' ? 'selected' : '' %>>Admin</option>
                </select>
              </div>
            </div>
            <div style="margin-top:16px;">
              <label class="field-label" style="font-size:12px;">Bio <span style="color:rgba(58,50,42,0.45);">(optional)</span></label>
              <textarea class="input" name="bio" rows="3" placeholder="Short bio…"><%= form.bio || '' %></textarea>
            </div>
          </section>

          <section class="settings-section">
            <h3>Password</h3>
            <div class="settings-field" style="max-width:360px;">
              <label class="field-label" style="font-size:12px;">Password</label>
              <input class="input" type="password" name="password" placeholder="At least 8 characters" autocomplete="new-password" required>
            </div>
          </section>

          <div class="btn-group">
            <button type="submit" class="btn btn-accent">Create user</button>
            <a href="/admin/users" class="btn btn-soft">Cancel</a>
          </div>
        </form>

      </div>
    </div>
  </main>
</div>
<%- include('partials/foot') %>
