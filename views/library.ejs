<%- include('partials/head', { title: 'Your library' }) %>
<div class="shell">
  <%- include('partials/sidebar') %>
  <main class="main">
    <%- include('partials/topbar', { pageTitle: 'Your library', searchAction: '/library' }) %>
    <div class="content">
      <div class="page">

        <p class="muted-line">
          <%= total %> <%= total === 1 ? 'story' : 'stories' %> in your library<%= query ? (' matching “' + query + '”') : '' %>.
        </p>

        <div class="panel" id="importDropzone" style="padding:16px 18px;margin-bottom:18px;">
          <button type="button" class="btn btn-soft" style="padding:8px 14px;border-radius:10px;font-size:13px;" id="importFoldersBtn">⇪ Import folders</button>
          <span id="importProgress" class="upload-progress" hidden></span>
          <div class="media-hint" style="margin-top:8px;">Each folder becomes its own private story — named after the folder, with its first photo as the cover. Click the button, then add as many folders as you like (one at a time, or drag several in), and import them together.</div>
        </div>
        <input type="file" id="importFolderInput" webkitdirectory directory multiple hidden>
        <script type="application/json" id="importFoldersData"><%- JSON.stringify(folders.map(function(f){ return { id: f.id, name: f.name }; })).replace(/</g, '\\u003c') %></script>

        <% if (books.length) { %>
          <div class="cover-grid">
            <% books.forEach(function(book){ %>
              <%- include('partials/cover-card', { book: book, opts: { showFav: true, foot: 'status-meta' } }) %>
            <% }) %>
          </div>

          <% if (totalPages > 1) { %>
            <% var qs = function(p){ return '/library?page=' + p + (query ? ('&q=' + encodeURIComponent(query)) : ''); }; %>
            <nav class="pager">
              <% if (page > 1) { %><a class="pager-btn" href="<%= qs(page - 1) %>">← Prev</a><% } else { %><span class="pager-btn disabled">← Prev</span><% } %>
              <% for (var p = 1; p <= totalPages; p++) { %>
                <% if (p === page) { %><span class="pager-num active"><%= p %></span><% } else { %><a class="pager-num" href="<%= qs(p) %>"><%= p %></a><% } %>
              <% } %>
              <% if (page < totalPages) { %><a class="pager-btn" href="<%= qs(page + 1) %>">Next →</a><% } else { %><span class="pager-btn disabled">Next →</span><% } %>
            </nav>
            <div class="pager-info">Page <%= page %> of <%= totalPages %></div>
          <% } %>
        <% } else { %>
          <div class="empty">
            <div class="ico">✦</div>
            <div class="et"><%= query ? 'No matching stories' : 'Your library is empty' %></div>
            <div class="eh"><%= query ? 'Try a different search.' : 'Start your first story to see it here.' %></div>
          </div>
        <% } %>

      </div>
    </div>
  </main>
</div>
<%- include('partials/foot') %>
