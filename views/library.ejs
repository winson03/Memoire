<%- include('partials/head', { title: 'Your library' }) %>
<div class="shell">
  <%- include('partials/sidebar') %>
  <main class="main">
    <%- include('partials/topbar', { pageTitle: 'Your library', searchAction: '/library' }) %>
    <div class="content">
      <div class="page">

        <!-- Tabs: All + one per folder / gallery collection name (matched names merge). -->
        <div class="gallery-tabs">
          <div class="sort-toggle">
            <a href="/library" class="<%= allActive ? 'active' : '' %>">All<span class="tab-count"><%= allCount %></span></a>
            <% tabs.forEach(function(t){ %>
              <a href="<%= t.href %>" class="<%= t.active ? 'active' : '' %>"><%= t.name %><span class="tab-count"><%= t.storyCount + t.photoCount %></span></a>
            <% }) %>
          </div>
        </div>

        <div style="display:flex;align-items:center;justify-content:space-between;gap:12px;flex-wrap:wrap;">
          <p class="muted-line" style="margin:0;">
            <% if (query) { %>
              <%= storyTotal %> <%= storyTotal === 1 ? 'story' : 'stories' %> matching “<%= query %>”<%= activeTab ? (' in “' + activeTab.name + '”') : '' %>.
            <% } else { %>
              <%= storyTotal %> <%= storyTotal === 1 ? 'story' : 'stories' %><% if (photoTotal) { %> · <%= photoTotal %> <%= photoTotal === 1 ? 'photo' : 'photos' %><% } %><%= activeTab ? (' in “' + activeTab.name + '”') : ' in your library' %>.
            <% } %>
          </p>
          <label class="folder-sort">Sort
            <select id="librarySortSelect">
              <option value="favourites" <%= sort === 'favourites' ? 'selected' : '' %>>Favourites first</option>
              <option value="latest" <%= sort === 'latest' ? 'selected' : '' %>>Latest first</option>
              <option value="oldest" <%= sort === 'oldest' ? 'selected' : '' %>>Oldest first</option>
              <option value="az" <%= sort === 'az' ? 'selected' : '' %>>Name A–Z</option>
              <option value="za" <%= sort === 'za' ? 'selected' : '' %>>Name Z–A</option>
            </select>
          </label>
        </div>

        <div class="panel" id="importDropzone" style="padding:16px 18px;margin-bottom:18px;">
          <div style="display:flex;flex-wrap:wrap;gap:8px;align-items:center;">
            <button type="button" class="btn btn-soft" style="padding:8px 14px;border-radius:10px;font-size:13px;" id="importFoldersBtn">⇪ Import folders</button>
            <button type="button" class="btn btn-soft" style="padding:8px 14px;border-radius:10px;font-size:13px;" id="importGalleryBtn">▦ Import gallery</button>
            <span id="importProgress" class="upload-progress" hidden></span>
          </div>
        </div>
        <input type="file" id="importFolderInput" webkitdirectory directory multiple hidden>
        <input type="file" id="importGalleryInput" accept="image/*,video/*" multiple hidden>
        <script type="application/json" id="importFoldersData"><%- JSON.stringify(folders.map(function(f){ return { id: f.id, name: f.name }; })).replace(/</g, '\\u003c') %></script>
        <script type="application/json" id="importCollectionsData"><%- JSON.stringify(collections.map(function(c){ return { id: c.id, name: c.name }; })).replace(/</g, '\\u003c') %></script>

        <% if (!items.length) { %>
          <div class="empty">
            <div class="ico">✦</div>
            <div class="et"><%= query ? 'No matching stories' : (activeTab ? ('Nothing in “' + activeTab.name + '” yet') : 'Your library is empty') %></div>
            <div class="eh"><%= query ? 'Try a different search.' : 'Start your first story, or add photos in the gallery, to see them here.' %></div>
          </div>
        <% } else { %>
          <!-- Stories and photos combined in one paginated grid. Photos are
               view-only here; uploading/managing them lives on the /gallery page. -->
          <div class="cover-grid" id="libraryCombined">
            <% items.forEach(function(it){ %>
              <% if (it.type === 'story') { %>
                <%- include('partials/cover-card', { book: it.book, opts: { showFav: true, foot: 'status-meta', lazyCover: true } }) %>
              <% } else { %>
                <div class="gallery-tile lib-photo" data-id="<%= it.img.id %>">
                  <button type="button" class="gallery-fav <%= it.img.is_favourite ? 'faved' : '' %>" aria-label="Favourite"><%= it.img.is_favourite ? '♥' : '♡' %></button>
                  <% if ((it.img.mime || '').startsWith('video/')) { %>
                    <video muted preload="metadata" data-full="/gallery/<%= it.img.id %>/raw"></video>
                    <div class="media-play">▶</div>
                  <% } else { %>
                    <img data-full="/gallery/<%= it.img.id %>/raw" alt="" loading="lazy">
                  <% } %>
                  <% if (it.img.file_name) { %><div class="tile-name" title="<%= it.img.file_name %>"><%= it.img.file_name %></div><% } %>
                </div>
              <% } %>
            <% }) %>
          </div>

          <% if (totalPages > 1) { %>
            <% var base = '/library?' + (activeTab ? ('tab=' + encodeURIComponent(activeTab.name) + '&') : '') + (query ? ('q=' + encodeURIComponent(query) + '&') : ''); %>
            <% var qs = function(p){ return base + 'page=' + p; }; %>
            <nav class="pager">
              <% if (page > 1) { %><a class="pager-btn" href="<%= qs(page - 1) %>">← Prev</a><% } else { %><span class="pager-btn disabled">← Prev</span><% } %>
              <% for (var p = 1; p <= totalPages; p++) { %>
                <% if (p === page) { %><span class="pager-num active"><%= p %></span><% } else { %><a class="pager-num" href="<%= qs(p) %>"><%= p %></a><% } %>
              <% } %>
              <% if (page < totalPages) { %><a class="pager-btn" href="<%= qs(page + 1) %>">Next →</a><% } else { %><span class="pager-btn disabled">Next →</span><% } %>
            </nav>
            <div class="pager-info">Page <%= page %> of <%= totalPages %></div>
          <% } %>
        <% } %>

      </div>
    </div>
  </main>
</div>
<%- include('partials/foot') %>
