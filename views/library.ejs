<%- include('partials/head', { title: 'Your library' }) %>
<div class="shell">
  <%- include('partials/sidebar') %>
  <main class="main">
    <%- include('partials/topbar', { pageTitle: 'Your library', searchAction: '/library' }) %>
    <div class="content">
      <div class="page">

        <!-- Tabs: All + one per folder / gallery collection name (matched names merge). -->
        <div class="gallery-tabs">
          <div class="sort-toggle">
            <a href="/library" class="<%= allActive ? 'active' : '' %>">All<span class="tab-count"><%= allCount %></span></a>
            <% tabs.forEach(function(t){ %>
              <a href="<%= t.href %>" class="<%= t.active ? 'active' : '' %>"><%= t.name %><span class="tab-count"><%= t.storyCount + t.photoCount %></span></a>
            <% }) %>
          </div>
        </div>

        <p class="muted-line">
          <% if (query) { %>
            <%= stories.length %> <%= stories.length === 1 ? 'story' : 'stories' %> matching “<%= query %>”<%= activeTab ? (' in “' + activeTab.name + '”') : '' %>.
          <% } else { %>
            <%= stories.length %> <%= stories.length === 1 ? 'story' : 'stories' %><% if (images.length) { %> · <%= images.length %> <%= images.length === 1 ? 'photo' : 'photos' %><% } %><%= activeTab ? (' in “' + activeTab.name + '”') : ' in your library' %>.
          <% } %>
        </p>

        <div class="panel" id="importDropzone" style="padding:16px 18px;margin-bottom:18px;">
          <button type="button" class="btn btn-soft" style="padding:8px 14px;border-radius:10px;font-size:13px;" id="importFoldersBtn">⇪ Import folders</button>
          <span id="importProgress" class="upload-progress" hidden></span>
          <div class="media-hint" style="margin-top:8px;">Each folder becomes its own private story — named after the folder, with its first photo as the cover. Click the button, then add as many folders as you like (one at a time, or drag several in), and import them together.</div>
        </div>
        <input type="file" id="importFolderInput" webkitdirectory directory multiple hidden>
        <script type="application/json" id="importFoldersData"><%- JSON.stringify(folders.map(function(f){ return { id: f.id, name: f.name }; })).replace(/</g, '\\u003c') %></script>

        <% if (!stories.length && !images.length) { %>
          <div class="empty">
            <div class="ico">✦</div>
            <div class="et"><%= query ? 'No matching stories' : (activeTab ? ('Nothing in “' + activeTab.name + '” yet') : 'Your library is empty') %></div>
            <div class="eh"><%= query ? 'Try a different search.' : 'Start your first story, or add photos in the gallery, to see them here.' %></div>
          </div>
        <% } %>

        <!-- Stories and photos combined in one grid. Photos are view-only here;
             uploading/managing them lives on the /gallery page. -->
        <% var showPhotos = images.length && !query; %>
        <% if (stories.length || showPhotos) { %>
          <div class="cover-grid" id="libraryCombined">
            <% stories.forEach(function(book){ %>
              <%- include('partials/cover-card', { book: book, opts: { showFav: true, foot: 'status-meta' } }) %>
            <% }) %>
            <% if (showPhotos) { images.forEach(function(img){ %>
              <div class="gallery-tile lib-photo" data-id="<%= img.id %>">
                <% if ((img.mime || '').startsWith('video/')) { %>
                  <video src="/gallery/<%= img.id %>/raw#t=0.1" muted preload="metadata" data-full="/gallery/<%= img.id %>/raw"></video>
                  <div class="media-play">▶</div>
                <% } else { %>
                  <img data-full="/gallery/<%= img.id %>/raw" alt="" loading="lazy">
                <% } %>
              </div>
            <% }) } %>
          </div>
        <% } %>

      </div>
    </div>
  </main>
</div>
<%- include('partials/foot') %>
