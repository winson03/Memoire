<%- include('partials/head', { title: 'Gallery' }) %>
<div class="shell">
  <%- include('partials/sidebar') %>
  <main class="main">
    <%- include('partials/topbar', { pageTitle: 'Gallery', searchAction: '/gallery' }) %>
    <div class="content">
      <div class="page">

        <% var collQ = activeCollection ? ('&collection=' + activeCollection.id) : ''; %>
        <% var sortQ = activeCollection ? ('&collection=' + activeCollection.id) : (favMode ? '&favourites=1' : ''); %>
        <% if (assignMode) { %>
          <div class="assign-head">
            <div>
              <div class="assign-title">Assign images to “<%= activeCollection.name %>”</div>
              <div class="assign-hint">Tap images to select. Ones already in this collection are pre-selected — untap to remove them.</div>
            </div>
          </div>
          <!-- Assign action bar: pinned at the top, like the select bar. -->
          <div class="assign-bar assign-bar-top" id="assignBar">
            <span class="assign-count" id="assignCount"></span>
            <div class="assign-actions">
              <a class="btn btn-soft" href="/gallery?order=<%= order %><%= collQ %>">Cancel</a>
              <button type="button" class="btn btn-accent" id="assignSave">Save</button>
            </div>
          </div>
        <% } else { %>
          <div class="gallery-tabs">
            <div class="sort-toggle">
              <a href="/gallery?order=<%= order %>" class="<%= !activeCollection && !favMode ? 'active' : '' %>">All</a>
              <% collections.forEach(function(c){ %>
                <a href="/gallery?order=<%= order %>&collection=<%= c.id %>" class="<%= activeCollection && activeCollection.id === c.id ? 'active' : '' %>"><%= c.name %><span class="tab-count"><%= collectionCounts[c.id] || 0 %></span></a>
              <% }) %>
            </div>
            <button class="btn btn-soft" style="padding:8px 14px;border-radius:100px;font-size:13px;"
                    data-create-dialog
                    data-title="New collection"
                    data-label="Collection name"
                    data-existing="<%= JSON.stringify(collections.map(function(c){ return c.name; })) %>"
                    data-action="/gallery/collections">+ New collection</button>
            <% if (activeCollection) { %>
              <form action="/gallery/collections/<%= activeCollection.id %>/delete" method="post" style="margin:0;">
                <button type="submit" class="btn-delete"
                        data-confirm
                        data-title="Delete collection?"
                        data-body="Deleting “<%= activeCollection.name %>” keeps its media — they go back to All.">Delete collection</button>
              </form>
            <% } %>
          </div>

          <div class="gallery-bar">
            <div class="sort-toggle">
              <a href="/gallery?order=fav<%= sortQ %>" class="<%= order === 'fav' ? 'active' : '' %>">♥ Favourites first</a>
              <a href="/gallery?order=newest<%= sortQ %>" class="<%= order === 'newest' ? 'active' : '' %>">Newest first</a>
              <a href="/gallery?order=oldest<%= sortQ %>" class="<%= order === 'oldest' ? 'active' : '' %>">Oldest first</a>
            </div>
            <div style="display:flex;align-items:center;gap:10px;">
              <% if (images.length) { %>
                <button type="button" class="btn btn-soft" id="gallerySelectBtn">Select</button>
              <% } %>
              <% if (activeCollection) { %>
                <a class="btn btn-soft" href="/gallery?order=<%= order %><%= collQ %>&assign=1">Assign images</a>
              <% } %>
              <span id="galleryProgress" class="upload-progress" hidden></span>
              <button type="button" class="btn btn-accent" id="galleryUploadBtn">+ Add media</button>
            </div>
          </div>

          <!-- Select-mode action bar: pinned at the top, right under Select. -->
          <div class="assign-bar assign-bar-top" id="gallerySelectBar" hidden>
            <span class="assign-count" id="gallerySelectCount">0 selected</span>
            <div class="assign-actions">
              <button type="button" class="btn btn-soft" id="gallerySelectCancel">Cancel</button>
              <% /* "Add to collection" only on the All tab; inside a collection, use "Assign images" to manage membership. */ %>
              <% if (collections.length && !activeCollection) { %>
                <button type="button" class="btn btn-accent" id="gallerySelectAssign">Add to collection</button>
              <% } %>
              <button type="button" class="btn btn-download" id="gallerySelectDownload">Download</button>
              <button type="button" class="btn btn-danger" id="gallerySelectDelete">Delete</button>
            </div>
          </div>
        <% } %>

        <input type="file" id="galleryInput" accept="image/*,video/*" multiple hidden>

        <div class="gallery-grid <%= assignMode ? 'select-mode' : '' %>" id="galleryGrid" data-order="<%= order %>"
             data-collection="<%= activeCollection ? activeCollection.id : '' %>"
             data-collections="<%- JSON.stringify(collections.map(function(c){ return { id: c.id, name: c.name }; })).replace(/"/g, '&quot;') %>"
             <% if (assignMode) { %>data-assign="1"<% } %><% if (favMode) { %> data-fav="1"<% } %>>
          <% images.forEach(function(img){ %>
            <% var inColl = assignMode && img.collection_id === activeCollection.id; %>
            <div class="gallery-tile <%= inColl ? 'selected' : '' %>" data-id="<%= img.id %>">
              <span class="tile-check" aria-hidden="true">✓</span>
              <% if (!assignMode) { %>
                <button type="button" class="gallery-fav <%= img.is_favourite ? 'faved' : '' %>" aria-label="Favourite"><%= img.is_favourite ? '♥' : '♡' %></button>
              <% } %>
              <% if ((img.mime || '').startsWith('video/')) { %>
                <video muted preload="metadata" data-full="/gallery/<%= img.id %>/raw"></video>
                <div class="media-play">▶</div>
              <% } else { %>
                <img src="/gallery/<%= img.id %>/raw?w=640" data-full="/gallery/<%= img.id %>/raw" alt="" loading="lazy">
              <% } %>
              <% if (img.file_name) { %><div class="tile-name" title="<%= img.file_name %>"><%= img.file_name %></div><% } %>
            </div>
          <% }) %>
        </div>

        <% /* Assign mode shows everything at once (its Save posts the whole
              selection), so it never paginates. */ %>
        <% if (!assignMode && totalPages > 1) { %>
          <%
            var gBase = '/gallery?order=' + order
              + (activeCollection ? ('&collection=' + activeCollection.id) : '')
              + (favMode ? '&favourites=1' : '') + '&page=';
            var qs = function(p){ return gBase + p; };
          %>
          <%- include('partials/pager', { page: page, totalPages: totalPages, qs: qs }) %>
          <div class="pager-info">Page <%= page %> of <%= totalPages %> · <%= total %> <%= total === 1 ? 'item' : 'items' %></div>
        <% } %>

        <div class="empty" id="galleryEmpty" <%= images.length ? 'hidden' : '' %>>
          <div class="ico"><%= favMode ? '♡' : '▦' %></div>
          <div class="et"><%= favMode ? 'No favourites yet' : (activeCollection ? ('Nothing in “' + activeCollection.name + '” yet') : 'No media yet') %></div>
          <div class="eh"><%= favMode ? 'Tap the heart on any image to add it here.' : (activeCollection ? 'Uploads while this tab is open land here, or move media in from All.' : 'Add photos or videos with + Add media — they’ll be sorted by date.') %></div>
        </div>

      </div>
    </div>
  </main>
</div>
<%- include('partials/foot') %>
