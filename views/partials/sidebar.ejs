<%
  var p = path || '';
  function isActive(key) {
    if (key === 'dashboard') return p.startsWith('/dashboard') || p.startsWith('/reader') || p.startsWith('/editor');
    if (key === 'admin') return p === '/admin'; // not /admin/users
    return p.startsWith('/' + key);
  }
  var u = currentUser || { name: 'Guest', initials: 'G', role: 'storyteller' };
  var navGroups = [
    { label: null, items: [
      { key: 'dashboard',  label: 'Dashboard',    href: '/dashboard' },
      { key: 'library',    label: 'Your library', href: '/library' },
      { key: 'discover',   label: 'Discover',     href: '/discover' },
    ] },
    { label: 'Organise', items: [
      { key: 'folders',    label: 'Folders',      href: '/folders' },
      { key: 'gallery',    label: 'Gallery',      href: '/gallery' },
      { key: 'favourites', label: 'Favourites',   href: '/favourites' },
    ] },
    { label: 'Account', items: [
      { key: 'reports',    label: 'Reports',      href: '/reports' },
      { key: 'profile',    label: 'Profile',      href: '/profile' },
      { key: 'settings',   label: 'Settings',     href: '/settings' },
    ] },
  ];
  // Admin links are only meaningful for admins — don't show dead links to everyone.
  if (u.role === 'admin') {
    navGroups.push({ label: 'Admin', items: [
      { key: 'admin',       label: 'Overview', href: '/admin' },
      { key: 'admin/users', label: 'Users',    href: '/admin/users' },
    ] });
  }
  var roleText = u.role === 'admin' ? 'Admin' : 'Storyteller';
%>
<aside class="sidebar" id="sidebar">
  <a href="/dashboard" class="sidebar-logo">
    <img src="/img/logo.png" class="sidebar-logo-img" alt="Mémoire">
  </a>
  <div class="new-btn-row">
    <a href="/editor" class="new-story-btn"><span>+</span> New story</a>
    <a href="/editor?type=novel" class="new-story-btn new-novel-btn"><span>+</span> New novel</a>
  </div>
  <nav class="nav">
    <% navGroups.forEach(function(g){ %>
      <% if (g.label) { %><div class="nav-group-label"><%= g.label %></div><% } %>
      <% g.items.forEach(function(n){ %>
        <a href="<%= n.href %>" class="nav-item <%= isActive(n.key) ? 'active' : '' %>">
          <span class="nav-dot"></span><%= n.label %>
        </a>
      <% }) %>
    <% }) %>
  </nav>
  <div class="sidebar-bottom">
    <% if (u.role === 'admin') { %>
      <div class="storage-pill <%= storageConnected ? '' : 'off' %>">
        <span class="live"></span>
        <span><%= storageConnected ? 'Storage connected' : 'Storage offline' %></span>
      </div>
    <% } %>
    <a href="/profile" class="user-row">
      <% if (avatarUrl(u)) { %>
        <div class="avatar" style="background-image:url(<%= avatarUrl(u) %>);background-size:cover;background-position:center;"></div>
      <% } else { %>
        <div class="avatar"><%= u.initials || 'U' %></div>
      <% } %>
      <div class="meta">
        <div class="name"><%= u.name %></div>
        <div class="role"><%= roleText %></div>
      </div>
    </a>
    <form action="/auth/logout" method="post" style="margin:0;">
      <button type="submit" class="signout-btn">Sign out</button>
    </form>
  </div>
</aside>
