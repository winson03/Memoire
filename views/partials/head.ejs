<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title><%= typeof title !== 'undefined' ? title + ' · Mémoire' : 'Mémoire' %></title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Hanken+Grotesk:wght@400;500;600;700&family=Newsreader:ital,opsz,wght@0,6..72,400;0,6..72,500;0,6..72,600;1,6..72,400;1,6..72,500&family=Outfit:wght@400;500;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/css/styles.css?v=<%= typeof assetVer === 'function' ? assetVer('css/styles.css') : '' %>">
</head>
<body>
<div class="page-loader" id="pageLoader"><div class="page-loader-spin"></div></div>
<div class="orbs">
  <div class="orb orb-a"></div>
  <div class="orb orb-b"></div>
  <div class="orb orb-c"></div>
</div>
<% if (typeof flash !== 'undefined' && flash && flash.length) { %>
  <% flash.forEach(function(f){ %>
    <div class="flash <%= f.type %>"><%= f.message %></div>
  <% }) %>
<% } %>
<div class="layer">
