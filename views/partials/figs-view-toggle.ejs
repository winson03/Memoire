<% /* List / grid layout switch for a story's galleries. Exactly one of these
      renders per page — it drives every .reader-figs on it. */ %>
<div class="figs-view-row">
  <div class="figs-view" id="figsView" role="group" aria-label="Photo layout">
    <button type="button" data-view="list" title="List view" aria-label="List view">☰</button>
    <button type="button" data-view="grid" title="Grid view" aria-label="Grid view">▦</button>
  </div>
</div>
