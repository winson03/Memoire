<%- include('partials/head', { title: 'Reset password' }) %>

<div class="login-wrap">
  <div class="login-card">
    <div class="login-mark">M</div>
    <h1>Set a new password</h1>
    <p class="sub">Choose a new password for your account.</p>

    <form method="post" action="/auth/reset-password" class="local-auth">
      <input type="hidden" name="token" value="<%= token %>">
      <input class="input" type="password" name="password" placeholder="New password (at least 6 characters)" autocomplete="new-password" required autofocus>
      <input class="input" type="password" name="confirm_password" placeholder="Confirm new password" autocomplete="new-password" required>
      <button type="submit" class="btn btn-accent" style="width:100%;justify-content:center;">Update password</button>
    </form>

    <a href="/login" class="back-home">← Back to sign in</a>
  </div>
</div>

<%- include('partials/foot') %>
