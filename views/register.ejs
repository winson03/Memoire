<%- include('partials/head', { title: 'Create account' }) %>

<div class="login-wrap">
  <div class="login-card reg-card">
    <img src="/img/logo-mark.png" class="login-mark-img" alt="Mémoire">
    <h1>Create your account</h1>
    <p class="sub">Join Mémoire to write, organise and publish your stories.</p>

    <form method="post" action="/auth/register" class="local-auth reg-form">
      <div class="field">
        <label class="field-label">Username</label>
        <input class="input" name="username" placeholder="Pick a username" autocomplete="username" required>
      </div>
      <div class="field">
        <label class="field-label">Email</label>
        <input class="input" type="email" name="email" placeholder="you@example.com" autocomplete="email" required>
      </div>
      <div class="field">
        <label class="field-label">Phone <span class="opt">(optional)</span></label>
        <input class="input" type="tel" name="phone" placeholder="Phone number" autocomplete="tel">
      </div>
      <div class="field">
        <label class="field-label">Date of birth <span class="opt">(optional)</span></label>
        <input class="input" type="date" name="dob" autocomplete="bday">
      </div>
      <div class="field full">
        <label class="field-label">Password</label>
        <input class="input" type="password" name="password" placeholder="At least 8 characters" autocomplete="new-password" required>
      </div>
      <button type="submit" class="btn btn-accent full" style="justify-content:center;margin-top:6px;">Create account</button>
    </form>

    <p class="login-fine">Already have an account? <a href="/login">Sign in</a>.</p>
    <a href="/" class="back-home">← Back home</a>
  </div>
</div>

<%- include('partials/foot') %>
