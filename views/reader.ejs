<%- include('partials/head', { title: openBook.title }) %>
<div class="shell">
  <%- include('partials/sidebar') %>
  <main class="main">
    <%- include('partials/topbar', { pageTitle: 'Reading', searchAction: '/dashboard' }) %>
    <div class="content">
      <div class="page tight">
        <a href="/dashboard" data-back class="btn-ghost" style="display:inline-block;margin-bottom:26px;">← Back</a>
        <div class="reader-col">

          <div class="reader-head">
            <div class="reader-cover">
              <div class="cover-spine <%= coverIsImage(openBook) ? 'has-image' : '' %>" style="background: <%= coverBackground(openBook) %>;">
                <span class="cover-series"><%= openBook.series || '' %></span>
                <div>
                  <div class="cover-title"><%= openBook.title %></div>
                  <div class="cover-author"><%= openBook.author %></div>
                </div>
              </div>
            </div>
            <div class="reader-meta">
              <span class="status" style="color: <%= statusColor(openBook.status) %>;"><span class="dot" style="background: <%= statusColor(openBook.status) %>;"></span><%= statusLabel(openBook.status) %></span>
              <h1><%= openBook.title %></h1>
              <div class="byline">By <% if (isOwner) { %><%= openBook.author %><% } else { %><a href="/u/<%= openBook.user_id %>" class="author-link"><%= openBook.author %></a><% } %> · <%= openBook.year %> · <%= metaRight(openBook) %> · <span class="reader-likes">♥ <%= openBook.likes || 0 %> likes</span></div>
              <div class="reader-actions">
                <form action="/stories/<%= openBook.id %>/favourite" method="post" style="margin:0;">
                  <input type="hidden" name="redirect" value="/reader/<%= openBook.id %>">
                  <button type="submit" class="btn btn-soft"><%= faved ? '♥ In favourites' : '♡ Add to favourites' %></button>
                </form>
                <a href="/stories/<%= openBook.id %>/download" class="btn btn-soft">⤓ Download</a>
                <% if (isOwner) { %>
                  <a href="/editor?id=<%= openBook.id %>" class="btn btn-accent">Edit story</a>
                  <button type="button" class="btn-danger-soft" style="width:auto;padding:11px 18px;"
                          data-confirm
                          data-title="Delete this story?"
                          data-body="“<%= openBook.title %>” and all its media will be permanently removed. This can’t be undone."
                          data-action="/stories/<%= openBook.id %>/delete">Delete this story</button>
                <% } %>
              </div>
            </div>
          </div>

          <% if (openBook.blurb) { %>
            <div class="reader-desc" data-expandable>
              <p class="blurb clamp"><%= openBook.blurb %></p>
              <button type="button" class="desc-toggle" hidden>Show more</button>
            </div>
          <% } %>

          <% if (openBook.type === 'novel') { %>
            <% if (blocks && blocks.length) { %>
              <div class="story-body">
                <% blocks.forEach(function(b){ %>
                  <% if (b.type === 'text') { %>
                    <p><%= b.value %></p>
                  <% } else if (b.type === 'image') { %>
                    <figure class="story-img">
                      <img class="story-img-lazy" data-full="/media/<%= b.mediaId %>" alt="" decoding="async">
                      <% if (b.caption) { %><figcaption><%= b.caption %></figcaption><% } %>
                    </figure>
                  <% } %>
                <% }) %>
              </div>
            <% } else if (isOwner) { %>
              <div class="empty"><div class="et">Nothing written yet</div><div class="eh">Open the editor and add paragraphs &amp; images to start.</div></div>
            <% } %>
          <% } else { %>
          <% if (photos.length || !endingTabs.length) { %>
            <div class="figs-view-row">
              <div class="figs-view" id="figsView" role="group" aria-label="Photo layout">
                <button type="button" data-view="list" title="List view" aria-label="List view">☰</button>
                <button type="button" data-view="grid" title="Grid view" aria-label="Grid view">▦</button>
              </div>
            </div>
          <% } %>
          <div class="reader-figs" id="readerFigs">
            <% if (photos.length) { %>
              <%- include('partials/story-figs', { media: photos }) %>
            <% } else if (!endingTabs.length) { %>
              <div class="empty"><div class="et">No media yet</div><div class="eh">Add photos and films in the editor.</div></div>
            <% } %>
          </div>

          <%
            /* Alternate endings: the story above stays put, and this section
               swaps between the endings' galleries. */
          %>
          <% if (endingTabs.length) { %>
            <section class="endings-section">
              <h3 class="h3">Endings</h3>
              <div class="ending-tabs" role="tablist" aria-label="Endings">
                <% endingTabs.forEach(function(t){ %>
                  <a class="ending-tab <%= t.id === openEndingId ? 'on' : '' %>"
                     href="/reader/<%= openBook.id %>?ending=<%= t.id %>"
                     role="tab" aria-selected="<%= t.id === openEndingId ? 'true' : 'false' %>"><%= t.label %></a>
                <% }) %>
              </div>
              <% if (isOwner && openEndingId) { %>
                <div class="ending-tools">
                  <a href="/editor?id=<%= openEndingId %>">Edit this ending</a>
                  <a href="/stories/<%= openEndingId %>/download">⤓ Download</a>
                </div>
              <% } %>
              <div class="reader-figs" id="endingFigs">
                <% if (endingPhotos.length) { %>
                  <%- include('partials/story-figs', { media: endingPhotos }) %>
                <% } else { %>
                  <div class="empty"><div class="et">Nothing in this ending yet</div><div class="eh">Open it in the editor to add photos and films.</div></div>
                <% } %>
              </div>
            </section>
          <% } %>
          <% } %>

          <% if (moreByAuthor.length) { %>
            <div class="more-from">
              <h3 class="h3" style="margin-bottom:20px;">More from <%= openBook.author %></h3>
              <div class="cover-grid xs">
                <% moreByAuthor.forEach(function(book){ %>
                  <%- include('partials/cover-card', { book: book, opts: { showFav: false, foot: 'none', titleSize: 18, hideAuthor: true } }) %>
                <% }) %>
              </div>
            </div>
          <% } %>

        </div>
      </div>
    </div>
  </main>
</div>
<%- include('partials/foot') %>
