# Copy to .env and fill in real values.

# App
PORT=8000
SESSION_SECRET=please-change-me
# How long a login stays valid, in days (default 365 = one year).
SESSION_MAX_AGE_DAYS=365
APP_URL=http://localhost:8000

# Local database (SQLite)
DATABASE_PATH=./data/memoire.db

# Telegram media storage
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_STORAGE_PATH=/telegram/media

# Self-hosted Telegram Bot API server (optional, enables up to 2 GB uploads)
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_BOT_API_URL=
TELEGRAM_BOT_API_LOCAL=false
TELEGRAM_BOT_API_CONTAINER_PATH=/var/lib/telegram-bot-api
TELEGRAM_BOT_API_DATA_PATH=
TELEGRAM_MAX_FILE_SIZE=50

# Email / SMTP (for password-reset links). If blank, reset emails are logged to the console.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=Mémoire <no-reply@example.com>

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# yt-dlp
GRAB_COOKIES_FROM_BROWSER=chrome
