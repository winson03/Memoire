# Copy to .env and fill in real values.

# App
PORT=8000
SESSION_SECRET=please-change-me
# How long a login stays valid, in days (default 365 = one year).
SESSION_MAX_AGE_DAYS=365
APP_URL=http://localhost:8000

# Local database (SQLite)
DATABASE_PATH=./data/memoire.db

# Telegram media storage
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_STORAGE_PATH=/telegram/media

# Self-hosted Telegram Bot API server (optional, enables up to 2 GB uploads)
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_BOT_API_URL=
TELEGRAM_BOT_API_LOCAL=false
TELEGRAM_BOT_API_CONTAINER_PATH=/var/lib/telegram-bot-api
TELEGRAM_BOT_API_DATA_PATH=
TELEGRAM_MAX_FILE_SIZE=50

# Google Drive — videos larger than GDRIVE_VIDEO_MIN_MB are stored here
# instead of Telegram (the public Bot API can't serve back files over 20 MB).
# Normal setup: leave these blank and connect from Settings → Storage →
# "Connect Google Drive" (admin; reuses the Google OAuth client above — first
# register <APP_URL>/settings/drive/callback as a redirect URI). The token is
# stored in the database; on hosts with an ephemeral disk (Render), copy the
# token shown on the Settings page into GDRIVE_OAUTH_REFRESH_TOKEN.
GDRIVE_OAUTH_REFRESH_TOKEN=
GDRIVE_VIDEO_MIN_MB=15

# Service-account mode (Google Workspace only): needs a shared drive folder —
# Google removed service accounts' own storage quota, so on a personal Gmail
# this mode cannot upload. Use the OAuth connect flow above instead.
GDRIVE_CREDENTIALS_FILE=
GDRIVE_SERVICE_ACCOUNT_EMAIL=
GDRIVE_PRIVATE_KEY=
GDRIVE_FOLDER_ID=

# Email / SMTP (for password-reset links). If blank, reset emails are logged to the console.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=Mémoire <no-reply@example.com>

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# yt-dlp
GRAB_COOKIES_FROM_BROWSER=chrome
